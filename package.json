{
  "name": "rayjs",
  "version": "0.2.0",
  "description": "Raytracer in One Weekend implementation",
  "author": "Jess Winter",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "raytracer",
    "creative-code",
    "graphics"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check --log-level=warn .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "code-check": "pnpm check && pnpm lint && pnpm fmt:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "nanostores": "^1.1.1"
  }
}
