{
  "name": "rayjs",
  "version": "0.2.0",
  "description": "Raytracer in One Weekend implementation",
  "author": "Jess Winter",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "raytracyer",
    "creative-code",
    "graphics"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check"
  },
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1"
  }
}
